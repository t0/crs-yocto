#!/usr/bin/env -S sdtgen

# XSA import - per https://github.com/Xilinx/system-device-tree-xlnx/blob/master/README.md
#
# Usage:
#
#     crs-yocto$ bin/sdtgen /path/to/t0-crs.xsa /path/to/t0-crs.dtsi
#
# This updates the files in the sdt/ directory.

# parse arguments
sdtgen set_dt_param -xsa [lindex $argv 0]
sdtgen set_dt_param -user_dts [lindex $argv 1]

# emit into sdt/
sdtgen set_dt_param -dir sdt

sdtgen generate_sdt
