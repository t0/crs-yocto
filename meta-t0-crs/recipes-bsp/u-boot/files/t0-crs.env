bootcmd=
	while true; do /* top-level loop - keep repeating until it works */

		display init;
		display logo;

		/* Try network boot with firmware discovery first */
		display write "DHCP..."

		echo Attempting network boot via firmware discovery;
		if dhcp; then
			display write "${ipaddr} fwdiscover...";

			/* Try firmware discovery */
			if fwdiscover 3 ${board_manufacturer}-${board_name}-rev${board_rev}; then

				/* Download payload */
				display write "${ipaddr} wget...";

				if wget ${firmware_url} ${loadaddr}; then
					display write "${ipaddr} fwdiscover exec...";

					/* Server tells us how to boot, or auto-detect if empty */
					if test -z "${firmware_boot_cmd}"; then

						/* Use iminfo to detect FIT vs raw script */
						if iminfo ${loadaddr}; then
							/* FIT image - try netboot script, fall back to bootm */
							if source ${loadaddr}:netboot; then
								echo BUG: Script returned;
							else
								bootm ${loadaddr};
							fi;
						else
							/* Not FIT - assume raw script */
							source ${loadaddr};
						fi;
					else
						/* Execute server-specified command */
						${firmware_boot_cmd};
						echo BUG: Boot command returned;
					fi;
				fi;
			else
				echo Firmware discovery timeout;
			fi;
		else
			echo DHCP failed;
		fi;

		/* Try MMC boot.scr */
		if fatload mmc 0 ${scriptaddr} boot.scr; then
			display write "${ipaddr} MMC...";
			setenv devtype mmc;
			setenv devnum 0;
			source ${scriptaddr};
		fi;

		/* Try NVMe boot.scr */
		if pci enum; then
			if nvme scan; then
				if fatload nvme 0 ${scriptaddr} boot.scr; then
					display write "${ipaddr} NVMe...";
					setenv devtype nvme;
					setenv devnum 0;
					source ${scriptaddr};
				fi;
			fi;
		fi;

		sleep 1;
	done
