bootcmd=
	display init;
	display logo;

	/* Short fwdiscover — allows pre-empting local boot from the network */
	display write "DHCP...";
	echo Attempting network boot via firmware discovery;
	setenv fwdiscover_timeout 3;
	if dhcp; then
		display write "${ipaddr} fwdiscover...";
		run fwdiscover_boot;
	else
		echo DHCP failed;
	fi;

	/* Try local boot media */
	setenv local_boot_found 0;

	/* Try MMC boot.scr (probe first to avoid crash on absent media) */
	if mmc dev 0; then
		if fatload mmc 0 ${scriptaddr} boot.scr; then
			display write "${ipaddr} MMC...";
			setenv devtype mmc;
			setenv devnum 0;
			setenv local_boot_found 1;
			source ${scriptaddr};
		fi;
	fi;

	/* Try NVMe boot.scr */
	if pci enum; then
		if nvme scan; then
			if fatload nvme 0 ${scriptaddr} boot.scr; then
				display write "${ipaddr} NVMe...";
				setenv devtype nvme;
				setenv devnum 0;
				setenv local_boot_found 1;
				source ${scriptaddr};
			fi;
		fi;
	fi;

	/* No local media — loop on fwdiscover indefinitely */
	if test "${local_boot_found}" = "0"; then
		echo No local boot media found - entering network boot loop;
		setenv fwdiscover_timeout 0;
		while true; do
			display write "fwdiscover (waiting)...";
			if dhcp; then
				display write "${ipaddr} fwdiscover...";
				run fwdiscover_boot;
			else
				echo DHCP failed;
			fi;
			sleep 1;
		done;
	fi;

	/* Local media was present but boot.scr failed — retry everything */
	echo Local boot failed - retrying;
	sleep 1;
	run bootcmd

fwdiscover_boot=
	if fwdiscover ${fwdiscover_timeout} ${board_manufacturer}-${board_name}-rev${board_rev}; then
		display write "${ipaddr} wget...";
		if wget ${firmware_url} ${loadaddr}; then
			display write "${ipaddr} fwdiscover exec...";
			if test -z "${firmware_boot_cmd}"; then
				if iminfo ${loadaddr}; then
					if source ${loadaddr}:netboot; then
						echo BUG: Script returned;
					else
						bootm ${loadaddr};
					fi;
				else
					source ${loadaddr};
				fi;
			else
				${firmware_boot_cmd};
				echo BUG: Boot command returned;
			fi;
		fi;
	else
		echo Firmware discovery timeout;
	fi
