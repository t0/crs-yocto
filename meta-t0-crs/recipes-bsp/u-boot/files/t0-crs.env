bootloader_version=0.1
bootloader=u-boot

bootcmd=
	display init;
	display logo;

	/* Short fwdiscover — allows pre-empting local boot from the network */
	setenv autoload no;
	display write "DHCP";

	echo Attempting network boot via firmware discovery;
	setenv fwdiscover_timeout 3;
	if dhcp; then
		display write "${ipaddr} fwdisc";
		if fwdiscover ${fwdiscover_timeout}; then
			echo "ipaddr = ${ipaddr}, ncip = ${ncip}, ncinport = ${ncinport}, ncoutport = ${ncoutport}";
			exit;
		else
			echo Firmware discovery timeout;
		fi;
	else
		echo DHCP failed;
	fi;

	/* Try local boot media */
	setenv local_boot_found 0;

	/* Try MMC boot.scr (probe first to avoid crash on absent media) */
	if mmc dev 0; then
		if fatload mmc 0 ${scriptaddr} boot.scr; then
			display write "${ipaddr} MMC";
			setenv devtype mmc;
			setenv devnum 0;
			setenv local_boot_found 1;
			source ${scriptaddr};
		fi;

		/* No boot.scr - try buildroot layout (single ext2, no partition table) */
		if test "${local_boot_found}" = "0"; then
			if ext2load mmc 0 ${kernel_addr_r} /boot/Image; then
				display write "${ipaddr} MMC/BR";
				ext2load mmc 0 ${fdt_addr_r} /boot/${board_manufacturer}-${board_name}-rev${board_rev}.dtb;
				setenv bootargs "earlycon console=ttyPS0,115200 ip=dhcp ro rootwait root=/dev/mmcblk0";
				setenv local_boot_found 1;
				booti ${kernel_addr_r} - ${fdt_addr_r};
			fi;
		fi;
	fi;

	/* Try NVMe boot.scr, but cheeky check PCIe link status before
	 * enumerating (pci enum faults if no link partner is present). */
	if itest.l *0xfd480238 == 3; then
		if pci enum; then
			if nvme scan; then
				if fatload nvme 0 ${scriptaddr} boot.scr; then
					display write "${ipaddr} NVMe";
					setenv devtype nvme;
					setenv devnum 0;
					setenv local_boot_found 1;
					source ${scriptaddr};
				fi;
			fi;
		fi;
	fi;

	/* No local media — loop on fwdiscover indefinitely */
	if test "${local_boot_found}" = "0"; then
		echo No local boot media found;
		setenv fwdiscover_timeout 0;
		if fwdiscover ${fwdiscover_timeout}; then
			echo "ipaddr = ${ipaddr}, ncip = ${ncip}, ncinport = ${ncinport}, ncoutport = ${ncoutport}";
			exit;
		else
			echo Firmware discovery timeout;
		fi;
	fi;

